                {
                    "type": "info",
                    "title": "Check HCL for Hardware support on VCF 9.1",
                    "bullets": [
                        "Intel Skylake (Broadwell, Kabylake & Skylake) Processors no longer supported (deprecated in earlier releases), requires RPQ"
                    ]
